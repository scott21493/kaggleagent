# Kaggle Agent Arena Phase 0 local configuration template.
# Do not put secrets in this file. Copy to .env.local and keep it outside Git if it contains local paths.

ARENA_MODE=local
ARENA_PROVIDER_MODE=stub
ARENA_WORK_ROOT=./worktrees
ARENA_ARTIFACT_ROOT=./artifacts
ARENA_TRACE_ROOT=./traces
ARENA_NETWORK_DEFAULT=deny
ARENA_NETWORK_DOMAINS_ALLOWED=
ARENA_KILL_SWITCH=0

# Phase 0 hard ceilings. These are operational ceilings, not billing estimates.
ARENA_PHASE0_PROVIDER_CALL_CAP=12
ARENA_PHASE0_CODEX_CALL_CAP=6
ARENA_PHASE0_CLAUDE_CALL_CAP=6
ARENA_PHASE0_WALL_MINUTES_CAP=120
ARENA_PHASE0_PER_CALL_WALL_MINUTES_CAP=20
ARENA_PHASE0_SHELL_COMMAND_CAP=35
ARENA_PHASE0_FAILED_COMMAND_CAP=5
ARENA_PHASE0_REPEATED_SAME_FAILURE_PER_TASK_CAP=2
ARENA_PHASE0_WASTE_EVENTS_PER_TASK_CAP=3
ARENA_PHASE0_WASTE_EVENTS_PER_RUN_CAP=5
ARENA_PHASE0_INPUT_CHARS_CAP=900000
ARENA_PHASE0_OUTPUT_CHARS_CAP=250000
ARENA_PHASE0_KAGGLE_SUBMISSIONS_ALLOWED=0
ARENA_PHASE0_GPU_JOBS_ALLOWED=0

# Optional external CLI configuration. These must point outside the repo if used.
KAGGLE_CONFIG_DIR=
CODEX_HOME=
CLAUDE_CONFIG_DIR=
