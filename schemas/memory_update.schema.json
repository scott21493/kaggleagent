{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kaggle-agent-arena.local/schemas/memory_update.schema.json",
  "title": "MemoryUpdateProposal",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "proposal_id",
    "namespace",
    "operation",
    "claim",
    "delta",
    "evidence",
    "confidence",
    "expiry_or_revisit",
    "risk",
    "review_status"
  ],
  "properties": {
    "schema_version": {
      "const": "memory_update.v1"
    },
    "proposal_id": {
      "type": "string",
      "pattern": "^mem_[0-9]{4,}$"
    },
    "namespace": {
      "enum": [
        "invariants",
        "codebase",
        "research",
        "experiments",
        "sources",
        "self_improvement"
      ]
    },
    "operation": {
      "enum": [
        "add",
        "modify",
        "deprecate",
        "remove"
      ]
    },
    "claim": {
      "type": "string",
      "minLength": 5
    },
    "prior_claim": {
      "type": [
        "string",
        "null"
      ]
    },
    "delta": {
      "type": "string",
      "minLength": 5
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "type",
          "ref",
          "quote_or_summary"
        ],
        "properties": {
          "type": {
            "enum": [
              "file",
              "scoreboard",
              "trace",
              "external_citation",
              "human_note"
            ]
          },
          "ref": {
            "type": "string"
          },
          "quote_or_summary": {
            "type": "string"
          }
        }
      }
    },
    "confidence": {
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "expiry_or_revisit": {
      "type": "string"
    },
    "risk": {
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "review_status": {
      "enum": [
        "proposed",
        "accepted",
        "rejected",
        "needs_human"
      ]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "operation": {
            "enum": [
              "modify",
              "deprecate",
              "remove"
            ]
          }
        }
      },
      "then": {
        "required": [
          "prior_claim"
        ],
        "properties": {
          "prior_claim": {
            "type": "string",
            "minLength": 5
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "operation": {
            "const": "add"
          }
        }
      },
      "then": {
        "properties": {
          "prior_claim": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    }
  ]
}
